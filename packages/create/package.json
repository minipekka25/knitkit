{
  "name": "@knitkit/create",
  "version": "0.1.0",
  "description": "Scaffold a runnable knitkit starter (host + remote, shared singleton) in one command.",
  "type": "module",
  "bin": {
    "knitkit-create": "./dist/index.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "knitkit",
    "module-federation",
    "import-maps",
    "create",
    "starter"
  ],
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minipekka25/knitkit.git",
    "directory": "packages/create"
  },
  "homepage": "https://github.com/minipekka25/knitkit/tree/main/packages/create#readme",
  "bugs": "https://github.com/minipekka25/knitkit/issues",
  "license": "MIT"
}
