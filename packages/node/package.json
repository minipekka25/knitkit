{
  "name": "@knitkit/node",
  "version": "0.1.0",
  "description": "Node SSR for knitkit: module.register loader hooks, module cache, SRI, import-map serialization for hydration parity.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/register.js"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@knitkit/runtime": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.1.0",
    "typescript": "^6.0.3",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minipekka25/knitkit.git",
    "directory": "packages/node"
  },
  "homepage": "https://github.com/minipekka25/knitkit/tree/main/packages/node#readme",
  "bugs": "https://github.com/minipekka25/knitkit/issues",
  "license": "MIT"
}
